%%{init: {'theme': 'base', 'themeVariables': {'lineColor': '#000000', 'edgeLabelBackground': '#ffffff'}}}%%
graph TB
    subgraph "User/Browser"
        User[👤 User]
    end

    subgraph "Local / EC2 Docker Host"

        subgraph "Docker Network: portal-network"

            subgraph "Frontend Layer"
                FE["🌐 Frontend
React + TypeScript (Nginx)
Port: 3000"]
            end

            subgraph "Backend Services Layer"
                LS["🔐 Login Service
Spring Boot 3.5 (Java 17)
Port: 8081"]
                PS["📁 Project Service
Spring Boot 3.5 (Java 17)
Port: 8082"]
                SCS["🔍 Scan Service
Spring Boot 3.5 (Java 17)
Port: 8083"]
            end

            subgraph "Database Layer"
                LDB[("🗄️ login_db
MySQL 8.0
Port: 3306")]
                PDB[("🗄️ project_db
MySQL 8.0
Port: 3306")]
                SDB[("🗄️ scan_db
MySQL 8.0
Port: 3306")]
            end

            subgraph "SonarQube Stack"
                SQDB[("🐘 sonarqube_db
PostgreSQL 13
Port: 5432")]
                SQ["📊 SonarQube Server
v9.9.5 LTS (Community)
Port: 9001"]
            end

        end

    end

    subgraph "External Services"
        GH["🐙 GitHub
Repository Hosting"]
        DS["🤖 DeepSeek API
AI Fix Suggestions"]
    end

    subgraph "AWS (ap-southeast-1)"
        ECR["📦 Amazon ECR
nusiss_projectmanagementportal
4 images: login / project / scan / frontend"]
    end

    %% User to Frontend
    User -->|"HTTP :3000"| FE

    %% Frontend to Backend
    FE -->|"REST API :8081"| LS
    FE -->|"REST API :8082"| PS
    FE -->|"REST API :8083"| SCS

    %% Services to their own DBs
    LS -->|"JDBC"| LDB
    PS -->|"JDBC"| PDB
    SCS -->|"JDBC"| SDB

    %% Service-to-service
    PS -->|"HTTP :8081 (validate user)"| LS
    PS -->|"HTTP :8083 (trigger scan)"| SCS

    %% Scan Service to SonarQube
    SCS -->|"sonar-scanner CLI → HTTP :9001"| SQ
    SQ -->|"JDBC"| SQDB
    SQ -->|"Scan Results"| SCS

    %% External integrations
    PS -->|"GitHub API (repo metadata)"| GH
    SCS -->|"Git Clone (source code)"| GH
    SCS -->|"REST API (AI suggestions)"| DS

    %% CI/CD pushes images to ECR
    ECR -.->|"docker pull (deployment)"| FE
    ECR -.->|"docker pull (deployment)"| LS
    ECR -.->|"docker pull (deployment)"| PS
    ECR -.->|"docker pull (deployment)"| SCS

    %% Styling
    style FE fill:#4CAF50,color:#fff
    style LS fill:#2196F3,color:#fff
    style PS fill:#2196F3,color:#fff
    style SCS fill:#2196F3,color:#fff
    style LDB fill:#FF9800,color:#fff
    style PDB fill:#FF9800,color:#fff
    style SDB fill:#FF9800,color:#fff
    style SQDB fill:#FF9800,color:#fff
    style SQ fill:#9C27B0,color:#fff
    style ECR fill:#FF9800,color:#fff
    style GH fill:#24292e,color:#fff
    style DS fill:#333,color:#fff
